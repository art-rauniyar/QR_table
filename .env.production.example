# ============================================
# OrderWorder — Production Environment Variables
# ============================================
# Copy this file and set the values for your deployment.
# NEVER commit the actual .env.local or .env.production with real values.

# --- MongoDB Atlas ---
# Create a new database user with a strong password at https://cloud.mongodb.com
# Connection string format:
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

# --- NextAuth ---
# Generate a secure secret with:  openssl rand -base64 32
NEXTAUTH_SECRET=<paste-generated-secret-here>

# Set to your production URL (no trailing slash)
NEXTAUTH_URL=https://your-domain.com
